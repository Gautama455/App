<Window x:Class="App.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:App.UI"
        Title="AppStore" Height="450" Width="800"
        Background="Gray">
    <Grid>
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0, 50, 0, 0">

            <TextBlock Text="Логин"
                FontSize="12"
                HorizontalAlignment="Center"
                Margin="0, 0, 0, 5"/>
            <TextBox x:Name="TextBoxLogin"
                Width="200"
                Height="30"
                Text="Login"
                Margin="0, 0, 0, 10"/>

            <TextBlock Text="Пароль"
                FontSize="12"
                HorizontalAlignment="Center"
                Margin="0, 0, 0, 5"/>
            <TextBox x:Name="TextBoxPassword"
                Width="200"
                Height="30"
                Text="Password"
                Margin="0, 0, 0, 10"/>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0, 10, 0, 0">
                
                <Button x:Name="LoginButton"
                    Content="Войти"
                    Width="200"
                    Height="40"
                    HorizontalAlignment="Right"
                    Margin="0, 0, 5, 0"
                    Click="Login"/>

                <Button x:Name="LoginAsGuestButton"
                    Content="Войти как гость"
                    Width="200"
                    Height="40"
                    HorizontalAlignment="Left"
                    Margin="5, 0, 0, 0"
                    Click="LoginAsGuest"/>
            </StackPanel>

            <Button x:Name="RegistrationButton"
                Content="Зарегистрироваться"
                Width="200"
                Height="40"
                HorizontalAlignment="Center"
                Margin="0, 10, 0, 0"
                Click="Register"/>
        </StackPanel>
    </Grid>
</Window>
