<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Margin="20">

    <TextBlock Text="Управление пользователями"
        FontSize="24"
        FontWeight="Bold"
        Margin="0, 0, 0, 20"/>

    <Button x:Name="btn_load_users"
        Content="Загрузить список пользователей"
        Width="250"
        Height="40"
        Margin="0, 0, 0, 20"
        Background="#007ACC" 
        Foreground="White"
        FontWeight="Bold"/>

     <ListView x:Name="lv_users" 
              MinHeight="200"
              Margin="0,10,0,0">
        <ListView.View>
            <GridView>
                <GridViewColumn Header="ID" 
                                Width="50" 
                                DisplayMemberBinding="{Binding Id}"/>
                <GridViewColumn Header="Логин" 
                                Width="150" 
                                DisplayMemberBinding="{Binding Login}"/>
                <GridViewColumn Header="Email" 
                                Width="200" 
                                DisplayMemberBinding="{Binding Email}"/>
            </GridView>
        </ListView.View>
    </ListView>

    <TextBlock x:Name="txt_status" 
        Text="Готов" 
        Foreground="Gray" 
        Margin="0,10,0,0"/>
</StackPanel>